# ===========================================
# LOL Server - Local 개발 환경 변수
# ===========================================
# 사용법: 이 파일을 .env로 복사 후 값을 수정하세요
#   cp .env.example .env
# ===========================================

# --- Riot Games API ---
RIOT_API_KEY=your-riot-api-key-here

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USERNAME=postgres
DB_PASSWORD=1234

# --- ClickHouse ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=clickhouse

# --- Spring ---
SPRING_PROFILES_ACTIVE=local

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- BigQuery ---
# 통계 데이터소스 토글: clickhouse(기본) | bigquery
# bigquery로 두지 않으면 아래 BIGQUERY_* 변수는 무시됩니다
STATS_DATASOURCE=clickhouse
# STATS_DATASOURCE=bigquery 일 때만 필수
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=lol_analytics
# 인증 (둘 중 하나만 사용; 둘 다 비우면 ADC: gcloud auth application-default login 또는 GCP 워크로드 ID)
# 1) Service Account JSON 경로 - Spring Resource 표기 (file:/..., classpath:..., http://...)
BIGQUERY_CREDENTIALS_LOCATION=
# 2) Google ADC 표준 환경변수 (BIGQUERY_CREDENTIALS_LOCATION 비어있을 때 자동 사용)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa-key.json


# --- Riot RSO OAuth ---
RIOT_RSO_CLIENT_ID=your-riot-rso-client-id
RIOT_RSO_CLIENT_SECRET=your-riot-rso-client-secret

# --- Champion Stats Cache ---
CHAMPION_STATS_CACHE_ENABLED=true

# --- JWT ---
JWT_SECRET_KEY=local-dev-secret-key-must-be-at-least-256-bits-long-for-hs256
